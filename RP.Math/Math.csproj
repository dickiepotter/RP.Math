<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <AssemblyName>Math</AssemblyName>
    <RootNamespace>Math</RootNamespace>

    <!-- Assembly metadata migrated from the old Properties\AssemblyInfo.cs (now auto-generated). -->
    <AssemblyTitle>Math</AssemblyTitle>
    <Product>Math</Product>
    <Copyright>Copyright © 2008</Copyright>
    <Version>1.0.0.0</Version>
    <AssemblyVersion>1.0.0.0</AssemblyVersion>
    <FileVersion>1.0.0.0</FileVersion>
  </PropertyGroup>

  <!--
    Faithful port of the old project's explicit file set. SDK-style projects glob **\*.cs
    by default, so two sets of files are removed explicitly:
      - Tests\**  : the Tests project is nested in this folder; its sources belong to Tests.csproj.
      - TestStuff\Vector.cs : an obsolete duplicate of Vector.cs (same namespace and types);
                              it was never compiled by the original project.
  -->
  <ItemGroup>
    <Compile Remove="Tests\**\*.cs" />
    <Compile Remove="TestStuff\Vector.cs" />
  </ItemGroup>

  <!--
    Pre-build guard: the canonical, actively-maintained vector type now lives in the Vector
    subfolder (RP.Math.Vector3\Vector3.cs). This warns at build time if that source has changed
    since the legacy RP.Math Vector was last reconciled against it, so the divergence is visible.
    After reconciling, re-baseline by setting ExpectedVector3Hash to the value reported in the warning
    (or run: (Get-FileHash ..\Vector\RP.Math.Vector3\Vector3.cs -Algorithm SHA256).Hash.ToLower()).
  -->
  <Target Name="CheckCanonicalVector3" BeforeTargets="BeforeBuild;CoreCompile">
    <PropertyGroup>
      <CanonicalVector3Path>$([System.IO.Path]::GetFullPath('$(MSBuildThisFileDirectory)..\Vector\RP.Math.Vector3\Vector3.cs'))</CanonicalVector3Path>
      <!-- SHA256 of Vector3.cs that this library was last checked against. -->
      <ExpectedVector3Hash>75dde2f25f883719a7ee3d225778deb2364fe71afa1bb921bb1833499c4cef19</ExpectedVector3Hash>
    </PropertyGroup>

    <Warning Condition="!Exists('$(CanonicalVector3Path)')"
             Code="RPM001"
             Text="Canonical Vector3 source not found at '$(CanonicalVector3Path)'; cannot verify the legacy RP.Math Vector is up to date." />

    <GetFileHash Condition="Exists('$(CanonicalVector3Path)')"
                 Files="$(CanonicalVector3Path)"
                 Algorithm="SHA256"
                 HashEncoding="hex">
      <Output TaskParameter="Hash" PropertyName="ActualVector3Hash" />
    </GetFileHash>

    <Warning Condition="Exists('$(CanonicalVector3Path)') And '$(ActualVector3Hash.ToLowerInvariant())' != '$(ExpectedVector3Hash)'"
             Code="RPM002"
             Text="Canonical Vector3 has changed since RP.Math was last reconciled with it (expected SHA256 $(ExpectedVector3Hash), found $(ActualVector3Hash)). Review whether RP.Math\Vector.cs needs updating, then update &lt;ExpectedVector3Hash&gt; in Math.csproj. Source: $(CanonicalVector3Path)" />
  </Target>

</Project>
